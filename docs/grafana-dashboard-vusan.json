{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource scraping the vusan /metrics endpoint",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "Vusan",
  "uid": "vusan",
  "tags": ["vusan", "telegram", "bot"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "editable": true,
  "panels": [
    {
      "type": "row",
      "title": "Traffic",
      "id": 100,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Inbound messages by kind",
      "id": 1,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "mps", "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (kind) (rate(vusan_inbound_messages_total[$__rate_interval]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Private vs group",
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "mps", "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (chat_type) (rate(vusan_inbound_messages_total[$__rate_interval]))",
          "legendFormat": "{{chat_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "STT transcriptions by result",
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "mps", "custom": { "fillOpacity": 20 } }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (result) (rate(vusan_stt_transcriptions_total[$__rate_interval]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Agent",
      "id": 101,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Agent runs by outcome",
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(vusan_agent_runs_total[$__rate_interval]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Agent run duration p50 / p95",
      "id": 5,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(vusan_agent_run_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(vusan_agent_run_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Error ratio (1h)",
      "id": 6,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 18 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.05 }, { "color": "red", "value": 0.2 } ] }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(vusan_agent_runs_total{outcome=~\"provider_error|unexpected_error|overloaded\"}[1h])) / sum(increase(vusan_agent_runs_total[1h]))",
          "legendFormat": "errors",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "In-flight runs",
      "id": 7,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "targets": [
        { "expr": "vusan_agent_runs_inflight", "legendFormat": "in flight", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Runs (24h)",
      "id": 8,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 }, "overrides": [] },
      "targets": [
        { "expr": "sum(increase(vusan_agent_runs_total[24h]))", "legendFormat": "runs", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Busy rejections (24h)",
      "id": 9,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 }, "overrides": [] },
      "targets": [
        { "expr": "sum(increase(vusan_agent_runs_total{outcome=\"busy\"}[24h]))", "legendFormat": "busy", "refId": "A" }
      ]
    },
    {
      "type": "row",
      "title": "LLM",
      "id": 102,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Token rate by type",
      "id": 10,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "cps", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (type) (rate(vusan_llm_tokens_total[$__rate_interval]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Tokens (24h)",
      "id": 11,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] },
      "targets": [
        { "expr": "sum by (type) (increase(vusan_llm_tokens_total[24h]))", "legendFormat": "{{type}}", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "LLM calls per run (1h)",
      "id": 12,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 1 }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(increase(vusan_llm_calls_total[1h])) / sum(increase(vusan_agent_runs_total{outcome!=\"busy\"}[1h]))",
          "legendFormat": "calls/run",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Tools",
      "id": 103,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Tool calls (top 10)",
      "id": 13,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "expr": "topk(10, sum by (tool) (rate(vusan_tool_calls_total[$__rate_interval])))",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tool errors by tool",
      "id": 14,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 20 } }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (tool) (rate(vusan_tool_calls_total{result=\"error\"}[$__rate_interval]))",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Delivery",
      "id": 104,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Delivery items by outcome",
      "id": 15,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 42 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(vusan_delivery_items_total[$__rate_interval]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Sender fallbacks by kind",
      "id": 16,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 42 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 20 } }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (kind) (rate(vusan_delivery_fallbacks_total[$__rate_interval]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Scheduler",
      "id": 105,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 50 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Tasks fired by result (1h windows)",
      "id": 17,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 51 },
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "fillOpacity": 30 } }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (result) (increase(vusan_scheduler_tasks_fired_total[1h]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Task lateness p95",
      "id": 18,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 51 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(vusan_scheduler_task_lateness_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Enabled tasks",
      "id": 19,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 51 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 }, "overrides": [] },
      "targets": [
        { "expr": "vusan_scheduler_tasks_enabled", "legendFormat": "enabled", "refId": "A" }
      ]
    },
    {
      "type": "row",
      "title": "Audience",
      "id": 106,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 59 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Known chats",
      "id": 20,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 60 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 }, "overrides": [] },
      "targets": [ { "expr": "vusan_peers_chats_known", "refId": "A" } ]
    },
    {
      "type": "stat",
      "title": "Known users",
      "id": 21,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 60 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 }, "overrides": [] },
      "targets": [ { "expr": "vusan_peers_users_known", "refId": "A" } ]
    },
    {
      "type": "stat",
      "title": "Active chats (24h)",
      "id": 22,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 60 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 }, "overrides": [] },
      "targets": [ { "expr": "vusan_peers_chats_active{window=\"24h\"}", "refId": "A" } ]
    },
    {
      "type": "stat",
      "title": "Active users (24h)",
      "id": 23,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 60 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 }, "overrides": [] },
      "targets": [ { "expr": "vusan_peers_users_active{window=\"24h\"}", "refId": "A" } ]
    },
    {
      "type": "stat",
      "title": "Active chats (7d)",
      "id": 24,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 60 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 }, "overrides": [] },
      "targets": [ { "expr": "vusan_peers_chats_active{window=\"7d\"}", "refId": "A" } ]
    },
    {
      "type": "stat",
      "title": "Active users (7d)",
      "id": 25,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 60 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 }, "overrides": [] },
      "targets": [ { "expr": "vusan_peers_users_active{window=\"7d\"}", "refId": "A" } ]
    },
    {
      "type": "timeseries",
      "title": "Audience growth",
      "id": 26,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 64 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0, "custom": { "fillOpacity": 5 } }, "overrides": [] },
      "targets": [
        { "expr": "vusan_peers_chats_known", "legendFormat": "known chats", "refId": "A" },
        { "expr": "vusan_peers_users_known", "legendFormat": "known users", "refId": "B" },
        { "expr": "vusan_peers_chats_active{window=\"7d\"}", "legendFormat": "active chats 7d", "refId": "C" },
        { "expr": "vusan_peers_users_active{window=\"7d\"}", "legendFormat": "active users 7d", "refId": "D" }
      ]
    },
    {
      "type": "row",
      "title": "JVM / process",
      "id": 107,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 72 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Heap memory",
      "id": 27,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 73 },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})", "legendFormat": "used", "refId": "A" },
        { "expr": "sum(jvm_memory_committed_bytes{area=\"heap\"})", "legendFormat": "committed", "refId": "B" },
        { "expr": "sum(jvm_memory_max_bytes{area=\"heap\"})", "legendFormat": "max", "refId": "C" }
      ]
    },
    {
      "type": "timeseries",
      "title": "GC pause (avg / max)",
      "id": 28,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 73 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(jvm_gc_pause_seconds_sum[$__rate_interval])) / sum(rate(jvm_gc_pause_seconds_count[$__rate_interval]))",
          "legendFormat": "avg",
          "refId": "A"
        },
        { "expr": "max(jvm_gc_pause_seconds_max)", "legendFormat": "max", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Live threads",
      "id": 29,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 73 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0, "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "expr": "jvm_threads_live_threads", "legendFormat": "live", "refId": "A" },
        { "expr": "jvm_threads_daemon_threads", "legendFormat": "daemon", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU usage",
      "id": 30,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 81 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "expr": "process_cpu_usage", "legendFormat": "process", "refId": "A" },
        { "expr": "system_cpu_usage", "legendFormat": "system", "refId": "B" }
      ]
    },
    {
      "type": "stat",
      "title": "Uptime",
      "id": 31,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 81 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [ { "expr": "process_uptime_seconds", "refId": "A" } ]
    },
    {
      "type": "timeseries",
      "title": "Open file descriptors",
      "id": 32,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 81 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0, "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [ { "expr": "process_files_open_files", "legendFormat": "open", "refId": "A" } ]
    }
  ]
}
