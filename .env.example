TELEGRAM_BOT_TOKEN=1234567890:qwerty
OPENAI_API_KEY=sk-proj-qwerty
ALLOWED_IDS=123456789,-1001234567890

# LLM_PROVIDER selects the LLM backend. Supported values: openai (default), ollama, openai-compatible.
# LLM_PROVIDER=openai

# OPENAI_MODEL=gpt-5.4-nano

# Ollama (when LLM_PROVIDER=ollama). OLLAMA_MODEL is required; OLLAMA_BASE_URL defaults to http://localhost:11434.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# OpenAI-compatible local endpoint (when LLM_PROVIDER=openai-compatible).
# OPENAI_BASE_URL, OPENAI_API_KEY (any non-empty value if the server ignores it), and OPENAI_MODEL are all required.
# Examples: llama.cpp llama-server (http://localhost:8080), LM Studio (http://localhost:1234/v1), vLLM, text-generation-webui.
# OPENAI_BASE_URL=http://localhost:8080
# OPENAI_API_KEY=sk-no-key-required

# TAVILY_API_KEY=tvly-dev-qwerty
# ELEVENLABS_API_KEY=sk_qwerty
# GIPHY_API_KEY=qwerty

# ELEVENLABS_VOICE_ID=VD1if7jDVYtAKs4P0FIY
# ELEVENLABS_TTS_MODEL=eleven_v3
# ELEVENLABS_TTS_OUTPUT_FORMAT=mp3_44100_128

# OpenAI Whisper STT for incoming Telegram voice messages. Set OPENAI_STT_API_KEY (use the same value as OPENAI_API_KEY to reuse one account) to enable.
# OPENAI_STT_API_KEY=sk-proj-qwerty
# OPENAI_STT_MODEL=gpt-4o-transcribe
# OPENAI_STT_MAX_DURATION_SECONDS=300

# DB_FILE=data/db/vusan.db
# YT_DLP_PATH=yt-dlp
# YT_DLP_COOKIES_FILE=data/cookies/www.youtube.com_cookies.txt
